{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/api/qpay/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://merchant.qpay.mn" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
